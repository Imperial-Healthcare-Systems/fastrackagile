# ------------------------------------------------------------------
# Fastrack Agile — environment template
# Copy this file to `.env.local` and fill in the values.
# On a host like Vercel/Netlify, set these same keys in the project's
# Environment Variables settings instead of a file.
#
# Everything is NEXT_PUBLIC_* (runs in the browser). The Supabase anon key
# and Razorpay key_id are meant to be public; your data is protected by the
# Row Level Security policies in supabase/schema.sql.
# ------------------------------------------------------------------

# --- Supabase (required for the live backend) ---
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# --- Razorpay (leave blank for demo payments; paste key_id to accept real payments) ---
# Razorpay Dashboard → Settings → API Keys → Key Id (rzp_live_… or rzp_test_…)
# NOTE: only the public Key Id here — NEVER the Key Secret.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Site contact / integrations (optional; defaults are baked into the app) ---
NEXT_PUBLIC_ADMIN_EMAIL=info@fastrackagile.com
NEXT_PUBLIC_WHATSAPP=919966080123
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/your-event
NEXT_PUBLIC_CALL_FEE=99
NEXT_PUBLIC_REGISTER_FEE=499
